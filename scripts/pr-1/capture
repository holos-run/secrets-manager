#!/usr/bin/env bash
# PR #1 — capture the Holos Secrets Manager sidebar and About branding.
#
# Called by scripts/browser-capture-pr 1. Expects:
#   HOLOS_BACKEND_URL, PR_SCREENSHOT_DIR
set -euo pipefail

AB="agent-browser --session-name holos-dev"

echo "==> Capturing default sidebar branding"
$AB open "$HOLOS_BACKEND_URL/profile"
$AB wait --load networkidle
$AB wait --text "Holos Secrets Manager"
$AB screenshot "$PR_SCREENSHOT_DIR/sidebar-branding.png"

echo "==> Capturing About page branding and trademark copy"
$AB open "$HOLOS_BACKEND_URL/about"
$AB wait --load networkidle
$AB wait --text "About Holos Secrets Manager"
$AB wait --text "Holos is a trademark"
$AB screenshot "$PR_SCREENSHOT_DIR/about-branding.png"

echo "Screenshots saved to $PR_SCREENSHOT_DIR"
